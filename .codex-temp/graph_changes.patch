+def _render_graph_asciidag(
+    args: argparse.Namespace,
+) -> tuple[str | None, str | None]:
+    model_path: Path = args.model
+    try:
+        model = onnx.load_model(model_path)
+    except OSError as exc:
+        return None, str(exc)
+    return _format_onnx_graph_asciidag(
+        model,
+        full_node_names=bool(args.full_node_names),
+        hide_initializers=bool(args.hide_initializers),
+    ), None
+
+
+def _format_onnx_graph_asciidag(
+    model: onnx.ModelProto,
+    *,
+    full_node_names: bool = False,
+    hide_initializers: bool = False,
+) -> str:
+    graph = model.graph
+    nodes = list(graph.node)
+    if not nodes:
+        graph_name = graph.name or "(unnamed graph)"
+        return f"Graph: {graph_name}\n(no nodes)"
+
+    producer_by_tensor: dict[str, int] = {}
+    for index, node in enumerate(nodes):
+        for output_name in node.output:
+            if output_name:
+                producer_by_tensor[output_name] = index
+
+    input_names = {value.name for value in graph.input if value.name}
+    initializer_names = {value.name for value in graph.initializer if value.name}
+    external_names: list[str] = []
+    external_index_by_name: dict[str, int] = {}
+
+    def _ensure_external(name: str) -> int:
+        existing = external_index_by_name.get(name)
+        if existing is not None:
+            return existing
+        external_index = len(external_names)
+        external_names.append(name)
+        external_index_by_name[name] = external_index
+        return external_index
+
+    dependencies: dict[int, set[tuple[str, int]]] = {
+        index: set() for index in range(len(nodes))
+    }
+    for index, node in enumerate(nodes):
+        for input_name in node.input:
+            if not input_name:
+                continue
+            producer_index = producer_by_tensor.get(input_name)
+            if producer_index is not None and producer_index != index:
+                dependencies[index].add(("op", producer_index))
+                continue
+            if hide_initializers and input_name in initializer_names:
+                continue
+            external_index = _ensure_external(input_name)
+            dependencies[index].add(("ext", external_index))
+
+    child_count: dict[tuple[str, int], int] = {
+        ("op", index): 0 for index in range(len(nodes))
+    }
+    for ext_index in range(len(external_names)):
+        child_count[("ext", ext_index)] = 0
+    for parent_refs in dependencies.values():
+        for parent_ref in parent_refs:
+            child_count[parent_ref] += 1
+
+    labels: dict[tuple[str, int], str] = {}
+    parent_map: dict[tuple[str, int], list[tuple[str, int]]] = {}
+    for index, node in enumerate(nodes):
+        if full_node_names:
+            labels[("op", index)] = f"n{index} [{node.op_type}] {node.name or '(unnamed)'}"
+        else:
+            labels[("op", index)] = f"n{index} [{node.op_type}]"
+        parent_map[("op", index)] = []
+
+    for ext_index, name in enumerate(external_names):
+        if name in initializer_names:
+            kind = "Init"
+        elif name in input_names:
+            kind = "Input"
+        else:
+            kind = "External"
+        if full_node_names:
+            labels[("ext", ext_index)] = f"e{ext_index} [{kind}] {name}"
+        else:
+            labels[("ext", ext_index)] = f"e{ext_index} [{kind}]"
+        parent_map[("ext", ext_index)] = []
+
+    for child_index, parent_refs in dependencies.items():
+        sorted_refs = sorted(parent_refs, key=lambda ref: (ref[0], ref[1]))
+        parent_map[("op", child_index)] = sorted_refs
+
+    tips: list[tuple[str, int]] = [
+        ("op", index) for index in range(len(nodes)) if child_count[("op", index)] == 0
+    ]
+    if not tips:
+        tips = [("op", len(nodes) - 1)]
+
+    lines: list[str] = [f"Graph: {graph.name or '(unnamed graph)'}"]
+    visited: set[tuple[str, int]] = set()
+
+    def append_parents(
+        node_ref: tuple[str, int],
+        prefix: str,
+        is_last: bool,
+    ) -> None:
+        connector = "`- " if is_last else "|- "
+        label = labels[node_ref]
+        if node_ref in visited:
+            lines.append(f"{prefix}{connector}{label} (shared)")
+            return
+        lines.append(f"{prefix}{connector}{label}")
+        visited.add(node_ref)
+        parent_refs = parent_map[node_ref]
+        if not parent_refs:
+            return
+        child_prefix = f"{prefix}{'   ' if is_last else '|  '}"
+        for pos, parent_ref in enumerate(parent_refs):
+            append_parents(
+                parent_ref,
+                child_prefix,
+                pos == len(parent_refs) - 1,
+            )
+
+    for tip_pos, tip_ref in enumerate(tips):
+        append_parents(tip_ref, "", tip_pos == len(tips) - 1)
+
+    if not full_node_names:
+        lines.append("")
+        lines.append("Node legend:")
+        for index, node in enumerate(nodes):
+            lines.append(f"  n{index}: {node.name or '(unnamed)'}")
+        for ext_index, name in enumerate(external_names):
+            if name in initializer_names:
+                kind = "init"
+            elif name in input_names:
+                kind = "input"
+            else:
+                kind = "external"
+            lines.append(f"  e{ext_index}: {kind} {name}")
+
+    return "\n".join(lines)
+
+
+def _handle_graph(args: argparse.Namespace) -> int:
+    graph_text, error = _render_graph_asciidag(args)
+    if error:
+        print(error, file=sys.stderr)
+        return 1
+    if graph_text:
+        print(graph_text)
+    return 0
+
+
