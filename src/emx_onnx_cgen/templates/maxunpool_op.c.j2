EMX_NODE_FN void {{ op_name }}({{ dim_args }}{{ params | join(', ') }}) {
    for (idx_t n = 0; n < {{ batch }}; ++n) {
        for (idx_t c = 0; c < {{ channels }}; ++c) {
{% if spatial_rank == 1 %}
            for (idx_t ox = 0; ox < {{ out_spatial[0] }}; ++ox) {
                {{ output }}[n][c][ox] = {{ zero_literal }};
            }
            for (idx_t ix = 0; ix < {{ in_spatial[0] }}; ++ix) {
                const {{ indices_c_type }} out_index = {{ indices }}[n][c][ix];
                const {{ indices_c_type }} base = ({{ indices_c_type }})(((({{ indices_c_type }})n * {{ channels }} + ({{ indices_c_type }})c) * {{ inferred_out_spatial[0] }}));
                const {{ indices_c_type }} local = out_index - base;
                if (local >= 0 && local < ({{ indices_c_type }}){{ inferred_out_spatial[0] }}) {
                    {{ output }}[n][c][local] = {{ input0 }}[n][c][ix];
                }
            }
{% elif spatial_rank == 2 %}
            for (idx_t oh = 0; oh < {{ out_spatial[0] }}; ++oh) {
                for (idx_t ow = 0; ow < {{ out_spatial[1] }}; ++ow) {
                    {{ output }}[n][c][oh][ow] = {{ zero_literal }};
                }
            }
            for (idx_t ih = 0; ih < {{ in_spatial[0] }}; ++ih) {
                for (idx_t iw = 0; iw < {{ in_spatial[1] }}; ++iw) {
                    const {{ indices_c_type }} out_index = {{ indices }}[n][c][ih][iw];
                    const {{ indices_c_type }} base = ({{ indices_c_type }})((({{ indices_c_type }})n * {{ channels }} + ({{ indices_c_type }})c) * {{ inferred_out_spatial[0] }} * {{ inferred_out_spatial[1] }});
                    const {{ indices_c_type }} local = out_index - base;
                    if (local >= 0 && local < ({{ indices_c_type }})({{ inferred_out_spatial[0] }} * {{ inferred_out_spatial[1] }})) {
                        const idx_t oh = (idx_t)(local / ({{ indices_c_type }}){{ inferred_out_spatial[1] }});
                        const idx_t ow = (idx_t)(local % ({{ indices_c_type }}){{ inferred_out_spatial[1] }});
                        {{ output }}[n][c][oh][ow] = {{ input0 }}[n][c][ih][iw];
                    }
                }
            }
{% elif spatial_rank == 3 %}
            for (idx_t od = 0; od < {{ out_spatial[0] }}; ++od) {
                for (idx_t oh = 0; oh < {{ out_spatial[1] }}; ++oh) {
                    for (idx_t ow = 0; ow < {{ out_spatial[2] }}; ++ow) {
                        {{ output }}[n][c][od][oh][ow] = {{ zero_literal }};
                    }
                }
            }
            for (idx_t id = 0; id < {{ in_spatial[0] }}; ++id) {
                for (idx_t ih = 0; ih < {{ in_spatial[1] }}; ++ih) {
                    for (idx_t iw = 0; iw < {{ in_spatial[2] }}; ++iw) {
                        const {{ indices_c_type }} out_index = {{ indices }}[n][c][id][ih][iw];
                        const {{ indices_c_type }} base = ({{ indices_c_type }})((({{ indices_c_type }})n * {{ channels }} + ({{ indices_c_type }})c) * {{ inferred_out_spatial[0] }} * {{ inferred_out_spatial[1] }} * {{ inferred_out_spatial[2] }});
                        const {{ indices_c_type }} local = out_index - base;
                        if (local >= 0 && local < ({{ indices_c_type }})({{ inferred_out_spatial[0] }} * {{ inferred_out_spatial[1] }} * {{ inferred_out_spatial[2] }})) {
                            const idx_t od = (idx_t)(local / ({{ indices_c_type }})({{ inferred_out_spatial[1] }} * {{ inferred_out_spatial[2] }}));
                            const idx_t rem = (idx_t)(local % ({{ indices_c_type }})({{ inferred_out_spatial[1] }} * {{ inferred_out_spatial[2] }}));
                            const idx_t oh = rem / {{ inferred_out_spatial[2] }};
                            const idx_t ow = rem % {{ inferred_out_spatial[2] }};
                            {{ output }}[n][c][od][oh][ow] = {{ input0 }}[n][c][id][ih][iw];
                        }
                    }
                }
            }
{% endif %}
        }
    }
}
