EMX_NODE_FN void {{ op_name }}({{ params | join(', ') }}) {
{% if spatial_rank == 2 %}
{% set H = spatial_dims[0] %}
{% set W = spatial_dims[1] %}
    for (idx_t n = 0; n < {{ n }}; ++n) {
        for (idx_t h = 0; h < {{ H }}; ++h) {
            for (idx_t w = 0; w < {{ W }}; ++w) {
{% if align_corners %}
                const {{ acc_type }} y_coord = ({{ H }} > 1) ? (({{ acc_type }})-1 + ({{ acc_type }})2 * h / ({{ acc_type }})({{ H }} - 1)) : ({{ acc_type }})0;
                const {{ acc_type }} x_coord = ({{ W }} > 1) ? (({{ acc_type }})-1 + ({{ acc_type }})2 * w / ({{ acc_type }})({{ W }} - 1)) : ({{ acc_type }})0;
{% else %}
                const {{ acc_type }} y_coord = ({{ acc_type }})-1 + (({{ acc_type }})2 * h + ({{ acc_type }})1) / ({{ acc_type }}){{ H }};
                const {{ acc_type }} x_coord = ({{ acc_type }})-1 + (({{ acc_type }})2 * w + ({{ acc_type }})1) / ({{ acc_type }}){{ W }};
{% endif %}
{% if acc_type == c_type %}
                {{ grid }}[n][h][w][0] = {{ theta }}[n][0][0] * x_coord + {{ theta }}[n][0][1] * y_coord + {{ theta }}[n][0][2];
                {{ grid }}[n][h][w][1] = {{ theta }}[n][1][0] * x_coord + {{ theta }}[n][1][1] * y_coord + {{ theta }}[n][1][2];
{% else %}
                {{ grid }}[n][h][w][0] = ({{ c_type }})(({{ acc_type }}){{ theta }}[n][0][0] * x_coord + ({{ acc_type }}){{ theta }}[n][0][1] * y_coord + ({{ acc_type }}){{ theta }}[n][0][2]);
                {{ grid }}[n][h][w][1] = ({{ c_type }})(({{ acc_type }}){{ theta }}[n][1][0] * x_coord + ({{ acc_type }}){{ theta }}[n][1][1] * y_coord + ({{ acc_type }}){{ theta }}[n][1][2]);
{% endif %}
            }
        }
    }
{% else %}
{% set D = spatial_dims[0] %}
{% set H = spatial_dims[1] %}
{% set W = spatial_dims[2] %}
    for (idx_t n = 0; n < {{ n }}; ++n) {
        for (idx_t d = 0; d < {{ D }}; ++d) {
            for (idx_t h = 0; h < {{ H }}; ++h) {
                for (idx_t w = 0; w < {{ W }}; ++w) {
{% if align_corners %}
                    const {{ acc_type }} z_coord = ({{ D }} > 1) ? (({{ acc_type }})-1 + ({{ acc_type }})2 * d / ({{ acc_type }})({{ D }} - 1)) : ({{ acc_type }})0;
                    const {{ acc_type }} y_coord = ({{ H }} > 1) ? (({{ acc_type }})-1 + ({{ acc_type }})2 * h / ({{ acc_type }})({{ H }} - 1)) : ({{ acc_type }})0;
                    const {{ acc_type }} x_coord = ({{ W }} > 1) ? (({{ acc_type }})-1 + ({{ acc_type }})2 * w / ({{ acc_type }})({{ W }} - 1)) : ({{ acc_type }})0;
{% else %}
                    const {{ acc_type }} z_coord = ({{ acc_type }})-1 + (({{ acc_type }})2 * d + ({{ acc_type }})1) / ({{ acc_type }}){{ D }};
                    const {{ acc_type }} y_coord = ({{ acc_type }})-1 + (({{ acc_type }})2 * h + ({{ acc_type }})1) / ({{ acc_type }}){{ H }};
                    const {{ acc_type }} x_coord = ({{ acc_type }})-1 + (({{ acc_type }})2 * w + ({{ acc_type }})1) / ({{ acc_type }}){{ W }};
{% endif %}
{% if acc_type == c_type %}
                    {{ grid }}[n][d][h][w][0] = {{ theta }}[n][0][0] * x_coord + {{ theta }}[n][0][1] * y_coord + {{ theta }}[n][0][2] * z_coord + {{ theta }}[n][0][3];
                    {{ grid }}[n][d][h][w][1] = {{ theta }}[n][1][0] * x_coord + {{ theta }}[n][1][1] * y_coord + {{ theta }}[n][1][2] * z_coord + {{ theta }}[n][1][3];
                    {{ grid }}[n][d][h][w][2] = {{ theta }}[n][2][0] * x_coord + {{ theta }}[n][2][1] * y_coord + {{ theta }}[n][2][2] * z_coord + {{ theta }}[n][2][3];
{% else %}
                    {{ grid }}[n][d][h][w][0] = ({{ c_type }})(({{ acc_type }}){{ theta }}[n][0][0] * x_coord + ({{ acc_type }}){{ theta }}[n][0][1] * y_coord + ({{ acc_type }}){{ theta }}[n][0][2] * z_coord + ({{ acc_type }}){{ theta }}[n][0][3]);
                    {{ grid }}[n][d][h][w][1] = ({{ c_type }})(({{ acc_type }}){{ theta }}[n][1][0] * x_coord + ({{ acc_type }}){{ theta }}[n][1][1] * y_coord + ({{ acc_type }}){{ theta }}[n][1][2] * z_coord + ({{ acc_type }}){{ theta }}[n][1][3]);
                    {{ grid }}[n][d][h][w][2] = ({{ c_type }})(({{ acc_type }}){{ theta }}[n][2][0] * x_coord + ({{ acc_type }}){{ theta }}[n][2][1] * y_coord + ({{ acc_type }}){{ theta }}[n][2][2] * z_coord + ({{ acc_type }}){{ theta }}[n][2][3]);
{% endif %}
                }
            }
        }
    }
{% endif %}
}
