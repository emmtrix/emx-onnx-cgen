    int quant_val = ((int)(unsigned char){{ data }}{% for idx in data_index_parts %}[{% if idx == data_index_parts[quantize_axis] %}packed_idx{% else %}{{ idx }}{% endif %}]{% endfor %} >> bit_shift) & {{ bit_mask }};
{% else %}
    {{ compute_type }} quant_val = ({{ compute_type }})({{ data_signed_c_type }}){{ data }}{% for idx in data_index_parts %}[{{ idx }}]{% endfor %};
{% endif %}
    idx_t block_idx = {{ qaxis_output_var }} / {{ block_size }};
{% if has_zero_points %}
{% if zero_points_packed %}
    idx_t zp_byte_idx = block_idx * {{ bits }} / 8;
    idx_t zp_bit_shift = (block_idx * {{ bits }}) % 8;
    int zp = ((int)(unsigned char){{ zero_points }}{% for idx in data_index_parts %}[{% if idx == data_index_parts[quantize_axis] %}zp_byte_idx{% else %}{{ idx }}{% endif %}]{% endfor %} >> zp_bit_shift) & {{ bit_mask }};
{% else %}
    {{ compute_type }} zp = ({{ compute_type }})({{ data_signed_c_type }}){{ zero_points }}{% for idx in data_index_parts %}[{% if idx == data_index_parts[quantize_axis] %}block_idx{% else %}{{ idx }}{% endif %}]{% endfor %};
{% endif %}
{% else %}
    int zp = {{ default_zero_point }};
{% endif %}
    {{ compute_type }} scale = ({{ compute_type }}){{ scales }}{% for idx in data_index_parts %}[{% if idx == data_index_parts[quantize_axis] %}block_idx{% else %}{{ idx }}{% endif %}]{% endfor %};
    {{ output }}{% for var in output_loop_vars %}[{{ var }}]{% endfor %} = ({{ output_c_type }})(({{ compute_type }})quant_val - ({{ compute_type }})zp) * scale;
{% for _ in output_shape %}
