EMX_NODE_FN void {{ op_name }}({{ dim_args }}{{ params | join(', ') }}) {
    for (idx_t b = 0; b < {{ batch }}; ++b) {
        for (idx_t c = 0; c < {{ channels }}; ++c) {
            for (idx_t out_idx = 0; out_idx < {{ output_seq_len }}; ++out_idx) {
                {{ acc_type }} acc = {% if bias %}({{ acc_type }}){{ bias }}[c]{% else %}{{ acc_zero_literal }}{% endif %};
                for (idx_t k = 0; k < {{ kernel_size }}; ++k) {
                    const idx_t window_idx = out_idx + k;
                    {{ acc_type }} sample = {{ acc_zero_literal }};
                    if (window_idx < {{ pad }}) {
                        {% if past_state %}
                        sample = ({{ acc_type }}){{ past_state }}[b][c][window_idx];
                        {% endif %}
                    } else {
                        sample = ({{ acc_type }}){{ input0 }}[b][c][window_idx - {{ pad }}];
                    }
                    acc += sample * ({{ acc_type }}){{ weights }}[c][0][k];
                }
                {% if apply_silu %}
                acc = {{ silu_fn }}(acc);
                {% endif %}
                {{ output }}[b][c][out_idx] = ({{ c_type }})acc;
            }
            for (idx_t state_idx = 0; state_idx < {{ state_len }}; ++state_idx) {
                const idx_t concat_idx = {{ seq_len }} + state_idx;
                {{ c_type }} sample = {{ zero_literal }};
                if (concat_idx < {{ pad }}) {
                    {% if past_state %}
                    sample = {{ past_state }}[b][c][concat_idx];
                    {% endif %}
                } else {
                    sample = {{ input0 }}[b][c][concat_idx - {{ pad }}];
                }
                {{ present_state }}[b][c][state_idx] = sample;
            }
        }
    }
}
