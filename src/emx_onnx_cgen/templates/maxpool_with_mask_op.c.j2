EMX_NODE_FN void {{ op_name }}({{ dim_args }}{{ params | join(', ') }}) {
    for (idx_t n = 0; n < {{ batch }}; ++n) {
        for (idx_t c = 0; c < {{ channels }}; ++c) {
            for (idx_t oh = 0; oh < {{ out_h }}; ++oh) {
                for (idx_t ow = 0; ow < {{ out_w }}; ++ow) {
                    {{ c_type }} max_value = {{ min_literal }};
                    int any_valid = 0;
                    for (idx_t kh = 0; kh < {{ kernel_h }}; ++kh) {
                        const idx_t ih = oh * {{ stride_h }} + kh * {{ dilation_h }} - {{ pad_h }};
                        if (ih >= 0 && ih < {{ in_h }}) {
                            for (idx_t kw = 0; kw < {{ kernel_w }}; ++kw) {
                                const idx_t iw = ow * {{ stride_w }} + kw * {{ dilation_w }} - {{ pad_w }};
                                if (iw >= 0 && iw < {{ in_w }} && {{ mask }}[n][c][ih][iw] != 0) {
                                    {{ c_type }} val = {{ input0 }}[n][c][ih][iw];
                                    if (!any_valid || val > max_value) {
                                        max_value = val;
                                        any_valid = 1;
                                    }
                                }
                            }
                        }
                    }
                    {{ output }}[n][c][oh][ow] = any_valid ? max_value : {{ min_literal }};
                }
            }
        }
    }
}
