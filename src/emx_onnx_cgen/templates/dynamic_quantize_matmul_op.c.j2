EMX_NODE_FN void {{ op_name }}({{ dim_args }}{{ params | join(', ') }}) {
    {{ compute_type }} a_min = ({{ compute_type }})0;
    {{ compute_type }} a_max = ({{ compute_type }})0;
    for (idx_t i = 0; i < {{ m }}; ++i) {
        for (idx_t k = 0; k < {{ k }}; ++k) {
            {{ compute_type }} v = ({{ compute_type }}){{ input_a }}[i][k];
            a_min = {{ scalar_fn(SF.MINIMUM, compute_dtype) }}(a_min, v);
            a_max = {{ scalar_fn(SF.MAXIMUM, compute_dtype) }}(a_max, v);
        }
    }
    {{ compute_type }} a_scale = (a_max - a_min) / ({{ compute_type }})255;
    {{ compute_type }} a_zero_fp = {{ scalar_fn(SF.NEARBYINT, compute_dtype) }}(-a_min / a_scale);
    a_zero_fp = {{ scalar_fn(SF.MAXIMUM, compute_dtype) }}(a_zero_fp, ({{ compute_type }})0);
    a_zero_fp = {{ scalar_fn(SF.MINIMUM, compute_dtype) }}(a_zero_fp, ({{ compute_type }})255);
    int32_t a_zero = (int32_t)a_zero_fp;
    for (idx_t i = 0; i < {{ m }}; ++i) {
        for (idx_t j = 0; j < {{ n }}; ++j) {
{% if b_scale_per_column %}
            const {{ compute_type }} b_scale_val = ({{ compute_type }}){{ b_scale }}[j];
{% else %}
            const {{ compute_type }} b_scale_val = ({{ compute_type }}){{ b_scale }}[0];
{% endif %}
{% if has_b_zero %}
{% if b_zero_per_column %}
            const int32_t b_zero = (int32_t){{ b_zero_point }}[j];
{% else %}
            const int32_t b_zero = (int32_t){{ b_zero_point }}[0];
{% endif %}
{% else %}
            const int32_t b_zero = 0;
{% endif %}
            int64_t acc = 0;
            for (idx_t k = 0; k < {{ k }}; ++k) {
                {{ compute_type }} a_q_f = {{ scalar_fn(SF.NEARBYINT, compute_dtype) }}(({{ compute_type }}){{ input_a }}[i][k] / a_scale) + a_zero_fp;
                a_q_f = {{ scalar_fn(SF.MAXIMUM, compute_dtype) }}(a_q_f, ({{ compute_type }})0);
                a_q_f = {{ scalar_fn(SF.MINIMUM, compute_dtype) }}(a_q_f, ({{ compute_type }})255);
                int32_t b_v = (int32_t){{ input_b }}[k][j];
                acc += (int64_t)((int32_t)a_q_f - a_zero) * (int64_t)(b_v - b_zero);
            }
            {{ compute_type }} result = a_scale * b_scale_val * ({{ compute_type }})acc;
{% if has_bias %}
            result += ({{ compute_type }}){{ bias }}[j];
{% endif %}
            {{ output }}[i][j] = ({{ output_c_type }})result;
        }
    }
}
