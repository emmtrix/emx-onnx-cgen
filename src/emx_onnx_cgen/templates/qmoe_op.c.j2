EMX_NODE_FN void {{ op_name }}({{ dim_args }}{{ params | join(', ') }}) {
    for (int b = 0; b < {{ batch }}; ++b) {
        for (int j = 0; j < {{ model_dim }}; ++j) {
            {{ output }}[b][j] = {{ zero_literal }};
        }
    }
    for (int b = 0; b < {{ batch }}; ++b) {
        /* Select top-{{ k }} experts by router_probs */
        int selected_experts[{{ k }}];
        {{ acc_type }} selected_weights[{{ k }}];
        {
            int chosen[{{ k }}];
            for (int ki = 0; ki < {{ k }}; ++ki) {
                {{ c_type }} best_val = {{ min_literal }};
                int best_idx = 0;
                for (int e = 0; e < {{ num_experts }}; ++e) {
                    int already = 0;
                    for (int kj = 0; kj < ki; ++kj) {
                        if (chosen[kj] == e) { already = 1; break; }
                    }
                    if (!already && {{ router_probs }}[b][e] > best_val) {
                        best_val = {{ router_probs }}[b][e];
                        best_idx = e;
                    }
                }
                chosen[ki] = best_idx;
            }
            /* Compute routing weights */
            {{ acc_type }} weight_sum = ({{ acc_type }})0.0f;
            for (int ki = 0; ki < {{ k }}; ++ki) {
{% if router_weights %}
                weight_sum += ({{ acc_type }}){{ router_weights }}[b][chosen[ki]];
{% else %}
                weight_sum += ({{ acc_type }}){{ router_probs }}[b][chosen[ki]];
{% endif %}
            }
            for (int ki = 0; ki < {{ k }}; ++ki) {
                selected_experts[ki] = chosen[ki];
{% if router_weights %}
{% if normalize_routing_weights %}
                selected_weights[ki] = ({{ acc_type }}){{ router_weights }}[b][chosen[ki]] / weight_sum;
{% else %}
                selected_weights[ki] = ({{ acc_type }}){{ router_weights }}[b][chosen[ki]];
{% endif %}
{% else %}
{% if normalize_routing_weights %}
                selected_weights[ki] = ({{ acc_type }}){{ router_probs }}[b][chosen[ki]] / weight_sum;
{% else %}
                selected_weights[ki] = ({{ acc_type }}){{ router_probs }}[b][chosen[ki]];
{% endif %}
{% endif %}
            }
        }
        /* Process each selected expert */
        for (int ki = 0; ki < {{ k }}; ++ki) {
            int e = selected_experts[ki];
            {{ acc_type }} rw = selected_weights[ki];
            /* fc1: input[b] @ dequant(fc1_w[e]) → fc1_out[fc1_out_size] */
            {{ acc_type }} fc1_out[{{ fc1_out_size }}];
            for (int k2 = 0; k2 < {{ fc1_out_size }}; ++k2) {
                {{ acc_type }} acc = ({{ acc_type }})0.0f;
                for (int i = 0; i < {{ model_dim }}; ++i) {
                    {{ acc_type }} w = ({{ acc_type }})(signed char){{ fc1_w }}[e][k2][i] * ({{ acc_type }}){{ fc1_scales }}[e][k2];
                    acc += ({{ acc_type }}){{ input }}[b][i] * w;
                }
{% if fc1_bias %}
                acc += ({{ acc_type }}){{ fc1_bias }}[e][k2];
{% endif %}
                fc1_out[k2] = acc;
            }
            /* SwiGLU: gate=fc1_out[:fc2_in_size], value=fc1_out[fc2_in_size:] */
            {{ acc_type }} swiglu[{{ fc2_in_size }}];
            for (int k2 = 0; k2 < {{ fc2_in_size }}; ++k2) {
                {{ acc_type }} gate  = fc1_out[k2];
                {{ acc_type }} value = fc1_out[{{ fc2_in_size }} + k2];
                {{ acc_type }} sig = ({{ acc_type }})1.0f / (({{ acc_type }})1.0f + expf(-(float)gate));
                swiglu[k2] = gate * sig * (value + {{ beta_literal }});
            }
            /* fc2: swiglu @ dequant(fc2_w[e]) → fc2_out[model_dim] */
            for (int j = 0; j < {{ model_dim }}; ++j) {
                {{ acc_type }} acc = ({{ acc_type }})0.0f;
                for (int k2 = 0; k2 < {{ fc2_in_size }}; ++k2) {
                    {{ acc_type }} w = ({{ acc_type }})(signed char){{ fc2_w }}[e][k2][j] * ({{ acc_type }}){{ fc2_scales }}[e][k2];
                    acc += swiglu[k2] * w;
                }
{% if fc2_bias %}
                acc += ({{ acc_type }}){{ fc2_bias }}[e][j];
{% endif %}
                {{ output }}[b][j] += ({{ c_type }})(rw * acc);
            }
        }
    }
}
