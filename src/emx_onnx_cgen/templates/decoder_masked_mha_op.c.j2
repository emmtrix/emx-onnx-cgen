EMX_NODE_FN void {{ op_name }}({{ dim_args }}{{ params | join(', ') }}) {
    const {{ c_type }} scale = {{ scale_literal }};
    const {{ c_type }} mask_filter_value = {{ mask_filter_literal }};
{% if is_self_attn %}
    /* Self-attention: read past_seq_len, copy past cache, add current K/V */
    int cur_pos = (int){{ past_seq_len_input }}[0];
    for (int b = 0; b < {{ batch }}; ++b) {
        for (int h = 0; h < {{ num_heads }}; ++h) {
            for (int s = 0; s < {{ static_total_seq }}; ++s) {
                for (int d = 0; d < {{ head_size }}; ++d) {
                    {{ present_key }}[b][h][s][d] = {{ past_key }}[b][h][s][d];
                    {{ present_value }}[b][h][s][d] = {{ past_value }}[b][h][s][d];
                }
            }
        }
    }
    /* Write current K/V into cache at position cur_pos */
    for (int b = 0; b < {{ batch }}; ++b) {
        for (int h = 0; h < {{ num_heads }}; ++h) {
            for (int d = 0; d < {{ head_size }}; ++d) {
                {{ present_key }}[b][h][cur_pos][d] = {{ key }}[b][0][h * {{ head_size }} + d];
                {{ present_value }}[b][h][cur_pos][d] = {{ value }}[b][0][h * {{ head_size }} + d];
            }
        }
    }
    int total_seq = cur_pos + 1;
    for (int b = 0; b < {{ batch }}; ++b) {
        for (int h = 0; h < {{ num_heads }}; ++h) {
            /* Compute Q for head h */
            {{ c_type }} q[{{ head_size }}];
            for (int d = 0; d < {{ head_size }}; ++d) {
                q[d] = {{ query }}[b][0][h * {{ head_size }} + d];
            }
            /* Compute attention scores over [0..total_seq) */
            {{ c_type }} scores[{{ static_total_seq }}];
            {{ c_type }} max_score = {{ min_literal }};
            for (int ki = 0; ki < total_seq; ++ki) {
                {{ c_type }} score = {{ zero_literal }};
                for (int d = 0; d < {{ head_size }}; ++d) {
                    score += q[d] * {{ present_key }}[b][h][ki][d];
                }
                score *= scale;
                /* 2D key padding mask: mask_index[b][ki] = 1 valid, 0 masked */
                if ({{ mask_index }}[b][ki] == 0) {
                    score += mask_filter_value;
                }
                {% if attn_bias %}
                /* attention bias - broadcast [1,1,1,total_seq] or [1,1,1,max_seq] */
                score += ({{ c_type }}){{ attn_bias }}[0][0][0][ki];
                {% endif %}
                scores[ki] = score;
                if (score > max_score) max_score = score;
            }
            /* Softmax */
            {{ c_type }} sum_exp = {{ zero_literal }};
            for (int ki = 0; ki < total_seq; ++ki) {
                scores[ki] = expf(scores[ki] - max_score);
                sum_exp += scores[ki];
            }
            for (int ki = 0; ki < total_seq; ++ki) {
                scores[ki] /= sum_exp;
            }
            /* Weighted sum of values */
            for (int d = 0; d < {{ head_size }}; ++d) {
                {{ c_type }} acc = {{ zero_literal }};
                for (int ki = 0; ki < total_seq; ++ki) {
                    acc += scores[ki] * {{ present_value }}[b][h][ki][d];
                }
                {{ output }}[b][0][h * {{ head_size }} + d] = acc;
            }
        }
    }
{% else %}
    /* Cross-attention: K/V already [batch,heads,kv_seq,head_size] */
    for (int b = 0; b < {{ batch }}; ++b) {
        for (int h = 0; h < {{ num_heads }}; ++h) {
            {{ c_type }} q[{{ head_size }}];
            for (int d = 0; d < {{ head_size }}; ++d) {
                q[d] = {{ query }}[b][0][h * {{ head_size }} + d];
            }
            {{ c_type }} scores[{{ kv_seq }}];
            {{ c_type }} max_score = {{ min_literal }};
            for (int ki = 0; ki < {{ kv_seq }}; ++ki) {
                {{ c_type }} score = {{ zero_literal }};
                for (int d = 0; d < {{ head_size }}; ++d) {
                    score += q[d] * {{ key }}[b][h][ki][d];
                }
                score *= scale;
                if ({{ mask_index }}[b][ki] == 0) {
                    score += mask_filter_value;
                }
                scores[ki] = score;
                if (score > max_score) max_score = score;
            }
            {% if output_qk %}
            /* Output pre-softmax masked scores (QK) */
            for (int ki = 0; ki < {{ kv_seq }}; ++ki) {
                {{ qk_output }}[b][h][0][ki] = scores[ki];
            }
            {% endif %}
            /* Softmax */
            {{ c_type }} sum_exp = {{ zero_literal }};
            for (int ki = 0; ki < {{ kv_seq }}; ++ki) {
                scores[ki] = expf(scores[ki] - max_score);
                sum_exp += scores[ki];
            }
            for (int ki = 0; ki < {{ kv_seq }}; ++ki) {
                scores[ki] /= sum_exp;
            }
            for (int d = 0; d < {{ head_size }}; ++d) {
                {{ c_type }} acc = {{ zero_literal }};
                for (int ki = 0; ki < {{ kv_seq }}; ++ki) {
                    acc += scores[ki] * {{ value }}[b][h][ki][d];
                }
                {{ output }}[b][0][h * {{ head_size }} + d] = acc;
            }
        }
    }
{% endif %}
}
